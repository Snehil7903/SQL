550. Game Play Analysis IV



SELECT 
    ROUND(
        COUNT(a.player_id) / (SELECT COUNT(DISTINCT player_id) FROM Activity), 
    2) AS fraction
FROM Activity a
JOIN (
    -- Subquery to find the first login date for each player
    SELECT player_id, MIN(event_date) AS first_login
    FROM Activity
    GROUP BY player_id
) AS fl ON a.player_id = fl.player_id 
-- Join condition: only match if the login is exactly 1 day after the first login
AND a.event_date = DATE_ADD(fl.first_login, INTERVAL 1 DAY);